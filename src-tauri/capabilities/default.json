{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-save",
    "fs:allow-write-file",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$DOWNLOADS/*"
        },
        {
          "path": "$DOCUMENTS/*"
        },
        {
          "path": "$DESKTOP/*"
        },
         {
          "path": "$DESKTOP/kvitansiyalar/*"
        }
      ]
    }
  ]
}